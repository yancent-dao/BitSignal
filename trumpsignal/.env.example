# ─── LLM ───────────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-xxxx
OPENROUTER_MODEL=anthropic/claude-haiku-4-5

# ─── 信源 API ──────────────────────────────────────────────────────────────────
# Twitterapi.io 用于抓取 Trump 的 X 帖子（可选，有 Truth Social RSS 作备用）
TWITTERAPI_IO_KEY=

# ─── 支付 ──────────────────────────────────────────────────────────────────────
# Trust Wallet 在 Base 主网上的收款地址（只需地址，不需私钥）
PAYMENT_RECIPIENT_ADDRESS=0xYourTrustWalletBaseAddress

# 是否使用 Base 测试网（true=Sepolia 测试网，false=主网）
USE_TESTNET=true

# ─── AgentVerse / uAgents ──────────────────────────────────────────────────────
# 从 AgentVerse 控制台获取：https://agentverse.ai
AGENTVERSE_API_KEY=
AGENT_SEED_PHRASE=replace_with_your_random_seed_phrase
AGENT_PORT=8001

# ─── 服务配置 ──────────────────────────────────────────────────────────────────
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
# 对外公网地址（用于 webhook 回调、AgentVerse endpoint），本地开发可留空
PUBLIC_BASE_URL=https://your-deployment-url.com

# ─── 日志 ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs
